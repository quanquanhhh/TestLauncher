      m_Items: []
  - m_Id: 14537383213359104
    m_Localized: "Ch\xEDnh s\xE1ch b\u1EA3o m\u1EADt"
    m_Metadata:
      m_Items: []
  - m_Id: 14536281382281216
    m_Localized: "Th\u1EDDi gian c\xF2n l\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 14537169891057664
    m_Localized: "\u0110\u1EB7t l\u1EA1i n\u1EC1n"
    m_Metadata:
      m_Items: []
  - m_Id: 14537621605015552
    m_Localized: "Kh\u1EDFi \u0111\u1ED9ng l\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 14537597366132736
    m_Localized: "Kh\xF4i ph\u1EE5c mua h\xE0ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14537147560583168
    m_Localized: "\u0110\u1EB7t n\u1EC1n"
    m_Metadata:
      m_Items: []
  - m_Id: 14536772392673280
    m_Localized: "C\u1EEDa h\xE0ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14535809736990720
    m_Localized: "\u0110i\u1EC1u kho\u1EA3n"
    m_Metadata:
      m_Items: []
  - m_Id: 14786229923307520
    m_Localized: "Nh\u1EA5p v\xE0o qu\xE2n m\u1EA1t ch\u01B0\u1EE3c \u0111\u1EC3
      \u0111\u1EB7t v\xE0o l\u01B0\u1EDBi \u1EDF d\u01B0\u1EDBi c\xF9ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14786211518701568
    m_Localized: "H\u01B0\u1EDBng d\u1EABn \u0111\u1EA1o c\u1EE5 3"
    m_Metadata:
      m_Items: []
  - m_Id: 14786190408769536
    m_Localized: "H\u01B0\u1EDBng d\u1EABn \u0111\u1EA1o c\u1EE5 2"
    m_Metadata:
      m_Items: []
  - m_Id: 14786153092046848
    m_Localized: "H\u01B0\u1EDBng d\u1EABn \u0111\u1EA1o c\u1EE5 1"
    m_Metadata:
      m_Items: []
  - m_Id: 14786125455777792
    m_Localized: "Nh\u1EA5p \u0111\u1EC3 v\xE0o c\xE0i \u0111\u1EB7t"
    m_Metadata:
      m_Items: []
  - m_Id: 14786104568143872
    m_Localized: "Nh\u1EA5p \u0111\u1EC3 v\u1EC1 trang ch\u1EE7"
    m_Metadata:
      m_Items: []
  - m_Id: 14785827370786816
    m_Localized: "Kh\xF4ng c\xF3 m\u1EA1ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14785786912530432
    m_Localized: "Qu\u1ED1c gia b\u1ECB ch\u1EB7n"
    m_Metadata:
      m_Items: []
  - m_Id: 14785734563422208
    m_Localized: "Ch\u1EDD m\u1ED9t ch\xFAt v\xE0 th\u1EED l\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 14785711276646400
    m_Localized: "Kh\xF4ng \u0111\u1EE7 kim c\u01B0\u01A1ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14785653542051840
    m_Localized: "Kh\xF4ng \u0111\u1EE7 xu"
    m_Metadata:
      m_Items: []
  - m_Id: 14785584029851648
    m_Localized: "Kh\xF4ng c\xF3 l\u01B0\u1EE3t"
    m_Metadata:
      m_Items: []
  - m_Id: 14785555793797120
    m_Localized: "H\xF4m nay \u0111\xE3 nh\u1EADn"
    m_Metadata:
      m_Items: []
  - m_Id: 14785497631383552
    m_Localized: "Kh\xF4ng th\u1EC3 nh\u1EADn"
    m_Metadata:
      m_Items: []
  - m_Id: 14785434955898880
    m_Localized: "Ch\u01B0a \u0111\u1EBFn l\xFAc"
    m_Metadata:
      m_Items: []
  - m_Id: 14785387820310528
    m_Localized: "Kh\xF4i ph\u1EE5c mua h\xE0ng th\u1EA5t b\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 14785347001344000
    m_Localized: "Kh\xF4i ph\u1EE5c mua h\xE0ng th\xE0nh c\xF4ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14785305721004032
    m_Localized: "Mua h\xE0ng th\u1EA5t b\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 14785280056057856
    m_Localized: "Mua h\xE0ng th\xE0nh c\xF4ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14785243603361792
    m_Localized: "Kh\xF4ng \u0111\u1EE7 \u1EA3nh"
    m_Metadata:
      m_Items: []
  - m_Id: 14777488029081600
    m_Localized: "Thu th\u1EADp 7 ng\xE0y \u0111\u1EC3 m\u1EDF gi\u1EA3i th\u01B0\u1EDFng
      l\u1EDBn"
    m_Metadata:
      m_Items: []
  - m_Id: 14777322098221056
    m_Localized: "\u0110\xF3ng"
    m_Metadata:
      m_Items: []
  - m_Id: 14777088785866752
    m_Localized: "Ti\xEAu \u0111\u1EC1 gi\u1EA3m gi\xE1 b\xED m\u1EADt"
    m_Metadata:
      m_Items: []
  - m_Id: 14776793578168320
    m_Localized: "Gi\u1EA3m gi\xE1 b\xED m\u1EADt"
    m_Metadata:
      m_Items: []
  - m_Id: 14776458558136320
    m_Localized: "Ti\xEAu \u0111\u1EC1 th\u1EBB"
    m_Metadata:
      m_Items: []
  - m_Id: 14834737460109312
    m_Localized: "Ba qu\xE2n m\u1EA1t ch\u01B0\u1EE3c gi\u1ED1ng h\u1EC7t nhau s\u1EBD
      b\u1ECB lo\u1EA1i b\u1ECF"
    m_Metadata:
      m_Items: []
  - m_Id: 14834747740348416
    m_Localized: "X\xF3a t\u1EA5t c\u1EA3 qu\xE2n m\u1EA1t ch\u01B0\u1EE3c \u0111\u1EC3
      gi\xE0nh chi\u1EBFn th\u1EAFng!"
    m_Metadata:
      m_Items: []
  - m_Id: 14834757135589376
    m_Localized: "Chi\u1EBFn th\u1EAFng mang l\u1EA1i ph\u1EA7n th\u01B0\u1EDFng
      h\u1EADu h\u0129nh!"
    m_Metadata:
      m_Items: []
  - m_Id: 14834768552484864
    m_Localized: "B\u1EA1n c\xF3 th\u1EC3 nh\u1EADn th\xEAm nhi\u1EC1u h\xECnh \u1EA3nh
      v\xE0 xu th\xFA v\u1ECB!"
    m_Metadata:
      m_Items: []
  - m_Id: 14834800420806656
    m_Localized: "M\u1ED9t s\u1EF1 ki\u1EC7n m\u1EDBi \u0111\xE3 b\u1EAFt \u0111\u1EA7u!
      H\xE3y c\xF9ng xem n\xE0o!"
    m_Metadata:
      m_Items: []
  - m_Id: 14834816795369472
    m_Localized: "Ti\u1EBFp theo"
    m_Metadata:
      m_Items: []
  - m_Id: 14834832196853760
    m_Localized: "B\u1ECF qua"
    m_Metadata:
      m_Items: []
  - m_Id: 14838537814106112
    m_Localized: "Nh\u1EA5p v\xE0o \u0111\xE2y \u0111\u1EC3 tr\u1EDF l\u1EA1i s\u1EA3nh"
    m_Metadata:
      m_Items: []
  - m_Id: 14838664515641344
    m_Localized: "Nh\u1EA5p v\xE0o \u0111\xE2y \u0111\u1EC3 s\u1EEDa c\xE0i \u0111\u1EB7t
      tr\xF2 ch\u01A1i"
    m_Metadata:
      m_Items: []
