      m_Items: []
  - m_Id: 1944985100288
    m_Localized: "C\u1EA5p \u0111\u1ED9"
    m_Metadata:
      m_Items: []
  - m_Id: 1026694784049152
    m_Localized: "Lo\u1EA1i b\u1ECF qu\u1EA3ng c\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 1027754420428800
    m_Localized: "Lo\u1EA1i b\u1ECF qu\u1EA3ng c\xE1o b\u1EAFt bu\u1ED9c"
    m_Metadata:
      m_Items: []
  - m_Id: 1028305954627584
    m_Localized: "Lo\u1EA1i b\u1ECF qu\u1EA3ng c\xE1o bi\u1EC3u ng\u1EEF d\u01B0\u1EDBi
      c\xF9ng"
    m_Metadata:
      m_Items: []
  - m_Id: 1028531402661888
    m_Localized: "Lo\u1EA1i b\u1ECF qu\u1EA3ng c\xE1o xen k\u1EBD"
    m_Metadata:
      m_Items: []
  - m_Id: 1030462497972224
    m_Localized: "\u0110\u0103ng k\xFD"
    m_Metadata:
      m_Items: []
  - m_Id: 1069497182412800
    m_Localized: "V\xF2ng quay may m\u1EAFn"
    m_Metadata:
      m_Items: []
  - m_Id: 1069742196875264
    m_Localized: "Ti\xEAu \u0111\u1EC1 th\u1EED th\xE1ch h\xE0ng ng\xE0y"
    m_Metadata:
      m_Items: []
  - m_Id: 1077460555096064
    m_Localized: "G\xF3i qu\xE0 t\u1EB7ng c\xF3 th\u1EDDi h\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 1079420305891328
    m_Localized: "Nh\u1EEFng cu\u1ED9c g\u1EB7p g\u1EE1 \u0111\u1EB9p"
    m_Metadata:
      m_Items: []
  - m_Id: 1080215373963264
    m_Localized: "Quy\u1EC1n l\u1EE3i \u0111\u1ED9c quy\u1EC1n"
    m_Metadata:
      m_Items: []
  - m_Id: 1080641049681920
    m_Localized: "Th\u1EED th\xE1ch h\xE0ng ng\xE0y"
    m_Metadata:
      m_Items: []
  - m_Id: 1081228722003968
    m_Localized: "Qu\xE0 t\u1EB7ng b\xED m\u1EADt"
    m_Metadata:
      m_Items: []
  - m_Id: 1082224978255872
    m_Localized: "Qu\xE0 t\u1EB7ng h\xE0ng ng\xE0y"
    m_Metadata:
      m_Items: []
  - m_Id: 1082611160408064
    m_Localized: "VIP v\u0129nh vi\u1EC5n"
    m_Metadata:
      m_Items: []
  - m_Id: 1082880782852096
    m_Localized: "Ch\u01B0\u01A1ng tr\xECnh t\xE0i n\u0103ng"
    m_Metadata:
      m_Items: []
  - m_Id: 1084015266586624
    m_Localized: "C\u1EEDa h\xE0ng"
    m_Metadata:
      m_Items: []
  - m_Id: 1084481522196480
    m_Localized: "B\u1ED9 s\u01B0u t\u1EADp c\u1EE7a t\xF4i"
    m_Metadata:
      m_Items: []
  - m_Id: 1457103061737472
    m_Localized: "T\u1EA5t c\u1EA3 h\xECnh \u1EA3nh"
    m_Metadata:
      m_Items: []
  - m_Id: 1457326743969792
    m_Localized: "\u0110\u0103ng k\xFD tr\u1ECDn \u0111\u1EDDi v\xE0 m\u1EDF kh\xF3a
      t\u1EA5t c\u1EA3 b\u1ED9 s\u01B0u t\u1EADp! Nh\u1EADn ngay!"
    m_Metadata:
      m_Items: []
  - m_Id: 6084627997745152
    m_Localized: "Xu v\xE0 kim c\u01B0\u01A1ng mi\u1EC5n ph\xED h\xE0ng ng\xE0y"
    m_Metadata:
      m_Items: []
  - m_Id: 6084741801795584
    m_Localized: "Ph\u1EA7n th\u01B0\u1EDFng c\u1EA5p \u0111\u1ED9 g\u1EA5p \u0111\xF4i"
    m_Metadata:
      m_Items: []
  - m_Id: 6084797233717248
    m_Localized: "T\u1EA3i xu\u1ED1ng h\xECnh \u1EA3nh mi\u1EC5n ph\xED kh\xF4ng
      gi\u1EDBi h\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 6084861691781120
    m_Localized: "Ch\u01A1i kh\xF4ng gi\u1EDBi h\u1EA1n c\xE1c c\u1EA5p \u0111\u1ED9
      \u1EA9n"
    m_Metadata:
      m_Items: []
  - m_Id: 6084916700078080
    m_Localized: "Lo\u1EA1i b\u1ECF qu\u1EA3ng c\xE1o xen k\u1EBD v\xE0 bi\u1EC3u
      ng\u1EEF"
    m_Metadata:
      m_Items: []
  - m_Id: 6084981548212224
    m_Localized: "Lo\u1EA1i b\u1ECF t\u1EA5t c\u1EA3 c\xE1c lo\u1EA1i qu\u1EA3ng
      c\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 6095558525935616
    m_Localized: "Nh\u1EADn quy\u1EC1n l\u1EE3i VIP ngay v\xE0 t\u1EADn h\u01B0\u1EDFng
      m\u1ECDi \u0111\u1EB7c quy\u1EC1n!"
    m_Metadata:
      m_Items: []
